# NS-TEA Environment Configuration
# Copy this file to .env and fill in your values

# Google AI API Key (required for Gemini via ADK)
GOOGLE_API_KEY=your-google-api-key-here

# Model Configuration
NSTEA_MODEL_NAME=gemini-2.0-flash
NSTEA_TEMPERATURE=0.2
NSTEA_MAX_OUTPUT_TOKENS=4096

# Data Paths
NSTEA_FHIR_DATA_DIR=data/fhir
NSTEA_TEST_CASES_DIR=data/test_cases

# Logging
NSTEA_LOG_LEVEL=INFO
